{
  "expo": {
    "name": "MetroRide PH ",
    "slug": "metroride-ph",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/metroride-icon.png",
    "scheme": "fastshot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MetroRide PH uses your location to find the nearest MRT/LRT station. Location is never stored or uploaded.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MetroRide PH uses your location to find the nearest MRT/LRT station.",
        "NSMicrophoneUsageDescription": "MetroRide PH uses the microphone so you can speak your transit queries to MetroAI.",
        "NSCameraUsageDescription": "MetroRide PH uses the camera so you can upload station photos for AI analysis.",
        "NSPhotoLibraryUsageDescription": "MetroRide PH accesses your photo library so you can upload transit photos for AI analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/metroride-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.metrorideph.app",
      "versionCode": 300,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icons/metroride-icon.png",
      "backgroundColor": "#0A0F1E",
      "themeColor": "#00FFFF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/metroride-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MetroRide PH needs your location to find the nearest MRT/LRT station. Location data is never uploaded or stored."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/metroride-icon.png",
          "color": "#1A73E8",
          "defaultChannel": "transit-alerts",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": ""
    },
    "owner": "mr.vin",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcd1df95-0ee7-4a61-803c-606847af15a3"
      }
    }
  }
}